{
  "name": "backend",
  "version": "1.0.0",
  "description": "Smart AQI System – Node.js + Express + MongoDB + Socket.io",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "NODE_ENV=test jest --runInBand --forceExit --detectOpenHandles",
    "test:unit": "NODE_ENV=test jest tests/unit --runInBand --forceExit",
    "test:api": "NODE_ENV=test jest tests/api --runInBand --forceExit",
    "test:integration": "NODE_ENV=test jest tests/integration --runInBand --forceExit",
    "test:socket": "NODE_ENV=test jest tests/socket --runInBand --forceExit",
    "test:auth": "NODE_ENV=test jest tests/auth --runInBand --forceExit",
    "test:e2e": "NODE_ENV=test jest tests/e2e --runInBand --forceExit",
    "test:coverage": "NODE_ENV=test jest --runInBand --forceExit --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "models/**/*.js",
      "config/**/*.js"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "mongoose": "^9.4.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.0"
  }
}
